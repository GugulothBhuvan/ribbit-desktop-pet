# LLM configuration (gemini or krutrim)
LLM_PROVIDER=gemini

# Gemini API Configuration
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.5-flash

# Krutrim API Configuration (alternative provider)
KRUTRIM_API_KEY=your_krutrim_api_key_here
KRUTRIM_MODEL=Qwen/Qwen2.5-14B-Instruct  # or target model specified in TRD: Qwen 3.6 35B A3B

# Deepgram Voice API (Push-to-Talk speech-to-text AND spoken replies / Aura TTS)
DEEPGRAM_API_KEY=your_deepgram_api_key_here

# Text-to-speech: pet speaks its replies aloud.
# Only spoken when you talk TO it (voice/chat); ambient screen comments stay text.
TTS_ENABLED=1
TTS_PROVIDER=sarvam         # sarvam (Indian-English voices) | deepgram (US voices)

# Sarvam AI (Bulbul) — real Indian-English accent, matches the pet's persona.
SARVAM_API_KEY=your_sarvam_api_key_here
SARVAM_TTS_SPEAKER=karun    # male: karun, abhilash, hitesh, aditya, rahul, rohan, amit, dev...
                            # female: anushka, manisha, vidya, arya, ritu, priya, neha, pooja...
SARVAM_TTS_MODEL=bulbul:v2  # bulbul:v1 is RETIRED; API accepts v2 / v3 / v3-beta only
                            # (v3 uses a different speaker roster than the list above)
SARVAM_TTS_LANGUAGE=en-IN
SARVAM_TTS_SAMPLE_RATE=22050

# Deepgram Aura (used only when TTS_PROVIDER=deepgram; reuses DEEPGRAM_API_KEY)
TTS_VOICE=aura-asteria-en   # e.g. aura-orion-en, aura-luna-en

# Local Database configuration
DB_PATH=storage/pet_memory.db

# UI configuration
ANIMATION_SCALE=1.0
PET_VOLUME=0.8
SPEECH_TYPING_SPEED_MS=40
SPEECH_BUBBLE_COOLDOWN_SEC=10
WANDER_INTERVAL_MIN=2
WANDER_INTERVAL_MAX=5

# Persona — who the pet is. Leave unset to use the built-in default (Ribbit,
# a lazy-but-loyal buddy with sarcastic Indian-English humour who won't stop
# nagging you about your career). Override either field to make it your own.
#   PET_NAME=Ribbit
#   PET_PERSONA=You are <name>, a <species/vibe> who ... (tone, quirks, backstory)
# Note: the pet speaks in SHORT one-liners for unprompted asides, and in longer
# 2-4 sentence replies when you talk to it directly (voice / Hey <wake word>).
PET_NAME=Ribbit

# Optional: absolute path to YOUR project for git/pytest commentary (unset = disabled)
WATCH_PROJECT_DIR=

# Optional: minimum seconds between ambient AI invocations
AMBIENT_AI_COOLDOWN_SEC=20

# Optional: talk hotkey (e.g. ctrl+space, ctrl+alt+j).
# Heads up: ctrl+space is also IDE autocomplete; a global binding shadows it.
PTT_HOTKEY=ctrl+space

# Hands-free conversation mode: press the hotkey ONCE, then just talk back and
# forth — voice-activity detection auto-ends each turn and reopens the mic after
# the pet replies. Press the hotkey again (or go silent) to end. Set 0 to fall
# back to the old press-to-start / press-to-stop recording.
CONVERSATION_MODE=1
CONVERSATION_VAD_THRESHOLD=0.5      # raise if it cuts you off in noise, lower if it misses speech
CONVERSATION_ENDPOINT_MS=800        # trailing silence (ms) that ends your turn
CONVERSATION_IDLE_TIMEOUT_SEC=12    # end the session after this much silence

# Optional: local wake word (fully on-device via openWakeWord). OFF by default
# because it keeps the mic on continuously (processed locally; audio only
# leaves after the phrase triggers a recording). Requires: pip install -e .[voice]
WAKE_WORD_ENABLED=0
WAKE_WORD_MODEL=hey_jarvis
WAKE_WORD_RECORD_SEC=5
